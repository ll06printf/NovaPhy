{
    "name": "novaphy",
    "version-string": "0.1.0",
    "description": "A 3D physics engine for embodied intelligence",
    "dependencies": [
        "eigen3",
        "gtest"
    ],
    "features": {
        "ipc": {
            "description": "IPC support via libuipc (requires CUDA >= 12.4)",
            "dependencies": [
                "spdlog",
                "fmt",
                "nlohmann-json",
                "libigl",
                "cppitertools",
                "dylib",
                "magic-enum",
                "tinygltf",
                "tbb",
                "catch2",
                "urdfdom",
                "cpptrace",
                "octree"
            ]
        },
        "cmake-standalone": {
            "description": "CMake standalone build supprot",
            "dependencies": [
                "pybind11"
            ]
        }
    },
    "overrides": [
        { "name": "fmt", "version": "10.2.1" },
        { "name": "spdlog", "version": "1.12.0" }
    ]
}
