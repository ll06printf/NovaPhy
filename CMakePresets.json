{
    "version": 3,
    "configurePresets": [
        {
            "name": "default",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": {
                    "type": "FILEPATH",
                    "value": "F:/vcpkg/scripts/buildsystems/vcpkg.cmake"
                },
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "debug",
            "binaryDir": "${sourceDir}/build-debug",
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": {
                    "type": "FILEPATH",
                    "value": "F:/vcpkg/scripts/buildsystems/vcpkg.cmake"
                },
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "ipc",
            "displayName": "Release with IPC (libuipc + CUDA)",
            "binaryDir": "${sourceDir}/build-ipc",
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": {
                    "type": "FILEPATH",
                    "value": "F:/vcpkg/scripts/buildsystems/vcpkg.cmake"
                },
                "CMAKE_BUILD_TYPE": "Release",
                "NOVAPHY_WITH_IPC": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "default",
            "configurePreset": "default"
        },
        {
            "name": "debug",
            "configurePreset": "debug"
        },
        {
            "name": "ipc",
            "configurePreset": "ipc"
        }
    ]
}
