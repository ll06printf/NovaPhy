<robot name="two_link_demo">
  <link name="base">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="3.0"/>
      <inertia ixx="0.12" ixy="0" ixz="0" iyy="0.12" iyz="0" izz="0.12"/>
    </inertial>
    <visual>
      <origin xyz="0 0.2 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.6 0.4 0.6"/>
      </geometry>
      <material name="steel"/>
    </visual>
    <collision>
      <origin xyz="0 0.2 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.6 0.4 0.6"/>
      </geometry>
    </collision>
  </link>
  <link name="link1">
    <inertial>
      <origin xyz="0 0.4 0" rpy="0 0 0"/>
      <mass value="1.2"/>
      <inertia ixx="0.04" ixy="0" ixz="0" iyy="0.04" iyz="0" izz="0.02"/>
    </inertial>
    <visual>
      <origin xyz="0 0.4 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.16 0.8 0.16"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0.4 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.16 0.8 0.16"/>
      </geometry>
    </collision>
  </link>
  <link name="link2">
    <inertial>
      <origin xyz="0 0.35 0" rpy="0 0 0"/>
      <mass value="0.9"/>
      <inertia ixx="0.02" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.01"/>
    </inertial>
    <visual>
      <origin xyz="0 0.35 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.14 0.7 0.14"/>
      </geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="0 0.35 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.14 0.7 0.14"/>
      </geometry>
    </collision>
  </link>
  <joint name="joint1" type="revolute">
    <parent link="base"/>
    <child link="link1"/>
    <origin xyz="0 0.4 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="30" velocity="3"/>
  </joint>
  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0 0.8 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="20" velocity="3"/>
  </joint>
</robot>
